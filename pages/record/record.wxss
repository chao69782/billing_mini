/* 引用全局样式 */
@import '../../assets/iconfont.wxss';

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--brand-yellow); /* 整体背景黄色 */
  padding: 0;
  box-sizing: border-box;
  position: relative;
}

/* 顶部黄色背景区 */
.yellow-bg {
  height: env(safe-area-inset-top);
  background: var(--brand-yellow);
  flex-shrink: 0;
}

/* 主面板 */
.main-panel {
  flex: 1;
  background: #fff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  margin-top: 30rpx; /* 增加主面板与顶部的间距 */
}

/* Header */
.header {
  height: 88rpx;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}

.tabs {
  display: flex;
  gap: 60rpx;
  height: 88rpx;
  align-items: center;
}

.tab {
  font-size: 34rpx;
  color: #333;
  position: relative;
  height: 100%;
  display: flex;
  align-items: center;
  padding: 0 10rpx;
}

.tab.active {
  /* font-weight: bold; */
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 16rpx;
  left: 0;
  right: 0;
  height: 4rpx;
  background: var(--brand-yellow);
}

.settings-btn {
  position: absolute;
  left: 32rpx;
  top: 0;
  bottom: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: #333;
}

.cancel-btn {
  position: absolute;
  right: 32rpx;
  top: 0;
  bottom: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: #666;
}

/* Category List */
.category-scroll {
  flex: 1;
  width: 100%;
  background: #fff;
  overflow-y: auto;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 32rpx 20rpx;
  padding-bottom: 20rpx;
}

.category-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  transition: all 0.2s;
}

.category-item.selected .icon-wrap {
  background: var(--brand-yellow);
}

.icon-wrap .iconfont {
  width: 50rpx;
  height: 50rpx;
}

.name {
  font-size: 24rpx;
  color: #666;
}

.category-item.selected .name {
  color: #333;
  font-weight: 600;
}

/* Footer Area */
.footer {
  flex-shrink: 0;
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
  padding-bottom: env(safe-area-inset-bottom); /* 恢复默认padding，因为已经全屏覆盖 */
}

.amount-display {
  padding: 20rpx 32rpx;
  text-align: right;
  border-bottom: 1rpx solid #F1F5F9;
}

.amount-text {
  font-size: 64rpx;
  font-weight: 600;
  color: #333;
}

.remark-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #F1F5F9;
}

.remark-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 16rpx;
}

.remark-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 60rpx;
}

/* Keyboard */
.keyboard {
  background: #F8F9FA;
  padding: 10rpx 10rpx 20rpx 10rpx;
}

.key-row {
  display: flex;
  margin-bottom: 10rpx;
  gap: 10rpx;
}

.key-row:last-child {
  margin-bottom: 0;
}

.key {
  flex: 1;
  height: 100rpx;
  background: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #333;
  font-weight: 500;
  box-shadow: 0 2rpx 0 #E2E8F0;
}

.key-hover {
  background: #F1F5F9;
}

.func-key {
  font-size: 32rpx;
  padding: 0;
  position: relative; /* Ensure absolute child positions correctly */
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Picker styles */
.full-size-picker {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.picker-inner {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  box-sizing: border-box;
  padding: 10rpx 0; /* 添加一些内边距来更好地居中 */
}

.key-icon {
  font-size: 32rpx;
  line-height: 1;
}

.key-text {
  font-size: 20rpx;
  color: #666;
  line-height: 1;
}

.submit-key {
  background: var(--brand-yellow);
  font-weight: 600;
  box-shadow: 0 2rpx 0 #E6C200;
}

.submit-hover {
  opacity: 0.9;
}
