/* 引用全局样式 */
@import '../../assets/iconfont.wxss';

page {
  background: var(--bg-gray);
  height: 100%;
  box-sizing: border-box;
}

.container {
  min-height: 100%;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.content {
  padding: 32rpx;
}

/* 邀请码卡片 */
.invite-card {
  background: var(--bg);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 40rpx;
}

.invite-top {
  display: flex;
  flex-direction: column;
  margin-bottom: 48rpx;
}

.invite-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.invite-label {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
}

.invite-code {
  font-size: 55rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 0;
  letter-spacing: 4rpx;
  line-height: 1;
}

.invite-desc {
  font-size: 24rpx;
  color: var(--text-gray);
  flex: 1;
  padding-right: 20rpx;
}

.btn-copy {
  margin: 0;
  padding: 0;
  background: var(--brand-yellow);
  color: var(--text-main);
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 12rpx;
  width: 140rpx !important;
  height: 64rpx !important;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: var(--shadow-yellow);
}

/* 绑定输入框 */
.bind-card {
  background: var(--bg);
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 40rpx;
}

.code-input {
  flex: 1;
  height: 80rpx;
  background: var(--primary-bg);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.btn-bind {
  width: 140rpx;
  height: 80rpx;
  background: var(--brand-yellow);
  color: var(--text-main);
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

/* 成员列表 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
}

.member-count {
  background: var(--bg-tag);
  color: var(--text-secondary);
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.member-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.member-card {
  background: var(--bg);
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.avatar-box {
  position: relative;
  margin-right: 24rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--primary-bg);
}

.role-icon-owner {
  position: absolute;
  bottom: 0;
  right: 0;
  background: var(--brand-yellow);
  color: var(--text-main);
  font-size: 20rpx;
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 2rpx solid var(--bg);
  font-weight: 700;
}

.info-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
  gap: 12rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
}

.role-tag {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.tag-admin {
  background: var(--text-main);
  color: var(--bg);
}

.tag-member {
  background: var(--bg-tag);
  color: var(--text-secondary);
}

.sub-info {
  font-size: 24rpx;
  color: var(--text-gray);
}

.action-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.btn-action {
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.btn-remark {
  padding: 0 24rpx;
  background: var(--bg);
  border: 2rpx solid var(--bg-tag);
  color: var(--text-main);
}

.btn-delete {
  width: 64rpx;
  background: var(--bg-danger);
  color: var(--text-danger);
}

.empty-state {
  text-align: center;
  padding: 40rpx;
  color: var(--text-gray);
  font-size: 28rpx;
}
