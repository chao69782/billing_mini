  <view class="card asset-card">
    <view class="card-header">
      <text class="card-title">资产管家</text>
      <text class="arrow">›</text>
    </view>
    <view class="asset-content">
      <view class="asset-item">
        <text class="label">净资产</text>
        <text class="value">0.00</text>
      </view>
      <view class="asset-item">
        <text class="label">资产</text>
        <text class="value">0.00</text>
      </view>
      <view class="asset-item">
        <text class="label">负债</text>
        <text class="value">0.00</text>
      </view>
    </view>
  </view>
  -->

  <!-- 常用功能 -->
  <view class="card functions-card">
    <view class="card-header">
      <text class="card-title">常用功能</text>
    </view>
    <view class="grid-list">
      <view class="grid-item" bindtap="onCalculatorTap">
        <view class="icon-wrapper">
          <text class="iconfont icon-jisuanqi"></text>
        </view>
        <text class="grid-label">房贷计算器</text>
      </view>

    </view>
  </view>
</view>

<custom-tab-bar />
