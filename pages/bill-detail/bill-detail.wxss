.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

/* Header */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: calc(env(safe-area-inset-top) + 10rpx); /* Move down slightly */
  height: 88rpx; /* Standard nav bar height */
  padding-left: 20rpx;
  padding-right: 20rpx;
  background: #fff;
  position: relative;
  z-index: 100;
  box-sizing: content-box; /* Ensure padding doesn't eat height */
}

.header-left {
  /* width: 80rpx; */ /* Removed fixed width */
  min-width: 80rpx;
  height: 100%;
  display: flex;
  align-items: center;
  gap: 20rpx;
  z-index: 101; /* Ensure clicks work above center if overlapping */
}

.header-center {
  position: absolute;
  left: 0;
  right: 0;
  top: auto; /* Uses padding-top from parent? No, absolute ignores parent padding for positioning usually? Wait. */
  bottom: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none; /* Let clicks pass through to sides if needed, but tabs need clicks */
}

.segment-control {
  pointer-events: auto; /* Re-enable clicks for tabs */
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  padding: 4rpx;
  box-sizing: border-box;
  border: 1rpx solid #333;
  height: 64rpx;
}

.header-right {
  width: 80rpx;
  height: 100%;
  display: flex;
  align-items: center;
}

.segment-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #333;
  border-radius: 12rpx;
}

.segment-item.active {
  background: #333;
  color: var(--brand-yellow);
  font-weight: 500;
}

.year-picker {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.year-picker .arrow {
  font-size: 24rpx;
  margin-left: 8rpx;
  color: #666;
}

.year-picker.hidden {
  visibility: hidden;
}

/* Summary Card */
.summary-card {
  margin: 0 32rpx 32rpx;
  background: var(--brand-yellow);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  position: relative;
  overflow: hidden;
  color: #333;
  box-shadow: 0 8rpx 20rpx rgba(255, 218, 68, 0.3);
}

.summary-header {
  font-size: 28rpx;
  opacity: 0.8;
  margin-bottom: 16rpx;
}

.summary-balance {
  display: flex;
  align-items: baseline;
  margin-bottom: 40rpx;
}

.summary-balance .currency {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.summary-balance .amount {
  font-size: 50rpx;
  font-weight: 600;
  line-height: 1;
}

.summary-row {
  display: flex;
  gap: 60rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.summary-item .label {
  font-size: 24rpx;
  opacity: 0.7;
}

.summary-item .value {
  font-size: 32rpx;
  font-weight: 500;
}

.bg-icon {
  position: absolute;
  right: -20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 200rpx;
  color: rgba(255, 255, 255, 0.3);
  font-weight: bold;
  pointer-events: none;
}

/* List Header */
.list-header {
  display: flex;
  padding: 20rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 24rpx;
  color: #999;
}

.col {
  text-align: left;
}

.col-1 { width: 15%; }
.col-2 { width: 25%; text-align: right; }
.col-3 { width: 25%; text-align: right; }
.col-4 { width: 35%; text-align: right; display: flex; justify-content: flex-end; align-items: center; }

/* List Content */
.list-content {
  flex: 1;
  min-height: 0;
}

.list-item {
  display: flex;
  padding: 32rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx;
  color: #333;
  align-items: center;
}

.list-item .col-2, .list-item .col-3 {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}
