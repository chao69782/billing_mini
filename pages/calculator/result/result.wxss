page {
  background-color: #fff;
  --brand-yellow: #FFDA44;
  --text-main: #333;
  --text-light: #999;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* Tabs */
.tabs {
  display: flex;
  background: #fff;
  justify-content: center;
  padding-top: 20rpx;
  flex-shrink: 0;
}

.tab-item {
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  color: #666;
  position: relative;
  font-weight: 500;
}

.tab-item.active {
  color: var(--text-main);
  font-weight: 600;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: var(--brand-yellow);
  border-radius: 4rpx;
}

/* Card */
.card-wrapper {
  padding: 20rpx;
  flex-shrink: 0;
}

.result-card {
  background: var(--brand-yellow); /* Using brand yellow as requested */
  border-radius: 20rpx;
  padding: 30rpx 30rpx;
  color: var(--text-main); /* Black text on yellow for contrast */
  box-shadow: 0 8rpx 20rpx rgba(255, 218, 68, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* If the user insists on the blue card from screenshot but yellow theme, 
   I should probably stick to yellow for consistency as "main color".
   The text color needs to be dark for yellow background. */

.card-header {
  font-size: 28rpx;
  opacity: 0.8;
  margin-bottom: 10rpx;
}

.card-amount {
  display: flex;
  align-items: baseline;
  margin-bottom: 10rpx;
}

.card-amount .amount {
  font-size: 80rpx;
  font-weight: 600;
  line-height: 1;
}

.card-amount .unit {
  font-size: 28rpx;
  margin-left: 10rpx;
}

.card-sub {
  font-size: 24rpx;
  opacity: 0.8;
  margin-bottom: 10rpx;
}

.card-grid {
  width: 100%;
  display: flex;
  justify-content: space-between;
  border-top: 1rpx solid rgba(0,0,0,0.1);
  padding-top: 30rpx;
  margin-top: 20rpx;
}

.grid-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.grid-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 10%;
  height: 80%;
  width: 1rpx;
  background: rgba(0,0,0,0.1);
}

.grid-item .label {
  font-size: 24rpx;
  opacity: 0.7;
  margin-bottom: 8rpx;
}

.grid-item .value {
  font-size: 32rpx;
  font-weight: 500;
}

/* Description */
.description {
  padding: 0 30rpx 30rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  flex-shrink: 0;
}

/* List */
.list-header {
  display: flex;
  padding: 20rpx 0;
  background: #f8f8f8;
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.col {
  text-align: center;
  flex-shrink: 0;
}

.col-1 { width: 12%; }
.col-2 { width: 22%; }
.col-3 { width: 22%; }
.col-4 { width: 22%; }
.col-5 { width: 22%; }

.list-content {
  flex: 1;
  background: #fff;
  min-height: 0; /* Important for scroll-view in flex */
}

.list-item {
  display: flex;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 26rpx;
  color: #333;
}

.list-item:nth-child(even) {
  background: #fafafa;
}
