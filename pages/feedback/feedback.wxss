.container {
  min-height: 100vh;
  background: #f8f9fa;
  padding: 30rpx;
  box-sizing: border-box;
}

.form-group {
  margin-bottom: 40rpx;
}

.form-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.textarea-wrap {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  position: relative;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.02);
}

.feedback-content {
  width: 100%;
  height: 300rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.placeholder {
  color: #999;
}

.word-count {
  text-align: right;
  font-size: 24rpx;
  color: #bbb;
  margin-top: 10rpx;
}

.contact-input {
  background: #fff;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  height: 88rpx;
  line-height: 88rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.02);
}

.submit-btn-wrap {
  margin-top: 60rpx;
  display: flex;
  justify-content: center;
}

.submit-btn {
  background: var(--brand-yellow, #FFDA44);
  color: #333;
  font-weight: 600;
  border-radius: 44rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  border: none;
  width: 80%; /* Limit width to look better centered */
  display: flex; /* Flex to center text inside button if needed, though line-height works */
  align-items: center;
  justify-content: center;
}

.submit-btn.disabled {
  background: #e5e5e5;
  color: #999;
}

.submit-btn::after {
  border: none;
}