.editor-container {
  background: #fff;
  padding-bottom: env(safe-area-inset-bottom);
}

.footer {
  flex-shrink: 0;
  background: #fff;
}

.amount-display {
  padding: 20rpx 32rpx;
  text-align: right;
  border-bottom: 1rpx solid #F1F5F9;
}

.amount-text {
  font-size: 64rpx;
  font-weight: 600;
  color: #333;
}

.remark-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #F1F5F9;
}

.remark-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 16rpx;
}

.remark-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 60rpx;
}

/* Keyboard */
.keyboard {
  background: #F8F9FA;
  padding: 10rpx 10rpx 20rpx 10rpx;
}

.key-row {
  display: flex;
  margin-bottom: 10rpx;
  gap: 10rpx;
}

.key-row:last-child {
  margin-bottom: 0;
}

.key {
  flex: 1;
  height: 100rpx;
  background: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #333;
  box-shadow: 0 2rpx 0 rgba(0,0,0,0.05);
  transition: all 0.1s;
}

.key-hover {
  background: #E2E8F0;
  transform: translateY(2rpx);
  box-shadow: none;
}

.func-key {
  /* font-size: 32rpx; */
}

.submit-key {
  background: var(--brand-yellow, #FFDA44);
  font-weight: 600;
}

.submit-hover {
  filter: brightness(0.95);
}

.full-size-picker {
  width: 100%;
  height: 100%;
}

.picker-inner {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  line-height: 1.2;
}

.key-icon {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.key-text {
  font-size: 24rpx;
  color: #666;
}